{
  "name": "quizzler-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright end-to-end journey for the quizzler system, used as a zero-downtime probe.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "loop": "./run-continuous.sh",
    "soak": "playwright test --repeat-each=200 --workers=1",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1"
  }
}
